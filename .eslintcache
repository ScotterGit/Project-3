[{"C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\index.js":"1","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\App.js":"2","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\Contact.js":"3","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\About.js":"4","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\Form.js":"5","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\FilterButton.js":"6","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\Nav.js":"7","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\Todo.js":"8"},{"size":397,"mtime":1611500694375,"results":"9","hashOfConfig":"10"},{"size":3305,"mtime":1611507378649,"results":"11","hashOfConfig":"10"},{"size":575,"mtime":1611515088907,"results":"12","hashOfConfig":"10"},{"size":294,"mtime":1611515049041,"results":"13","hashOfConfig":"10"},{"size":893,"mtime":1611506110588,"results":"14","hashOfConfig":"10"},{"size":434,"mtime":1611420144163,"results":"15","hashOfConfig":"10"},{"size":1098,"mtime":1611438366208,"results":"16","hashOfConfig":"10"},{"size":2302,"mtime":1611507425855,"results":"17","hashOfConfig":"10"},{"filePath":"18","messages":"19","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},"le51mm",{"filePath":"21","messages":"22","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"23","usedDeprecatedRules":"20"},{"filePath":"24","messages":"25","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"26","messages":"27","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"28","usedDeprecatedRules":"20"},{"filePath":"29","messages":"30","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"31","messages":"32","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"33","messages":"34","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"35","usedDeprecatedRules":"20"},{"filePath":"36","messages":"37","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\index.js",[],["38","39"],"C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\App.js",["40","41"],"import React, { useState } from \"react\";\r\nimport Form from \"./components/Form\";\r\nimport FilterButton from \"./components/FilterButton\";\r\nimport Todo from \"./components/Todo\";\r\nimport { nanoid } from \"nanoid\";\r\nimport Nav from \"./components/Nav\";\r\nimport {\r\n  BrowserRouter as Router,\r\n  Switch,\r\n  Route,\r\n  Link\r\n} from \"react-router-dom\";\r\nimport About from \"./About\";\r\nimport Contact from \"./Contact\";\r\n\r\nconst FILTER_MAP = {\r\n  All: () => true,\r\n  Active: task => !task.completed,\r\n  Completed: task => task.completed\r\n};\r\nconst FILTER_NAMES = Object.keys(FILTER_MAP);\r\n\r\n\r\nfunction App(props) {\r\n  \r\n// is this line in the correct spot? https://developer.mozilla.org/en-US/docs/Learn/Tools_and_testing/Client-side_JavaScript_frameworks/React_interactivity_events_state\r\n  const [tasks, setTasks] = useState(props.tasks);\r\n  const [filter, setFilter] = useState('All');\r\n\r\n\r\n  function addTask(name) {\r\n    const newTask = { id: \"todo-\" + nanoid(), name: name, completed: false };\r\n    setTasks([...tasks, newTask]);\r\n  }\r\n  function toggleTaskCompleted(id) {\r\n    const updatedTasks = tasks.map(task => {\r\n      // if this task has the same ID as the edited task\r\n      if (id === task.id) {\r\n        // use object spread to make a new object\r\n        // whose `completed` prop has been inverted\r\n        return {...task, completed: !task.completed}\r\n      }\r\n      return task;\r\n    });\r\n    setTasks(updatedTasks);\r\n  }\r\n\r\n  function editTask(id, newName) {\r\n    const editedTaskList = tasks.map(task => {\r\n    // if this task has the same ID as the edited task\r\n      if (id === task.id) {\r\n        //\r\n        return {...task, name: newName}\r\n      }\r\n      return task;\r\n    });\r\n    setTasks(editedTaskList);\r\n  }\r\n  const taskList = tasks\r\n  .filter(FILTER_MAP[filter])\r\n  .map(task => (\r\n    <Todo\r\n      id={task.id}\r\n      name={task.name}\r\n      completed={task.completed}\r\n      key={task.id}\r\n      toggleTaskCompleted={toggleTaskCompleted}\r\n      deleteTask={deleteTask}\r\n      editTask={editTask}\r\n    />\r\n  ));\r\n\r\n  const filterList = FILTER_NAMES.map(name => (\r\n    <FilterButton\r\n      key={name}\r\n      name={name}\r\n      isPressed={name === filter}\r\n      setFilter={setFilter}\r\n    />\r\n  ));\r\n\r\n  function deleteTask(id) {\r\n    const remainingTasks = tasks.filter(task => id !== task.id);\r\n    setTasks(remainingTasks);\r\n  }\r\n \r\n  const tasksNoun = taskList.length !== 1 ? 'tasks' : 'task';\r\nconst headingText = `${taskList.length} ${tasksNoun} remaining`;\r\n  return (\r\n    \r\n    <div className=\"todoapp stack-large\">\r\n      <Router>\r\n          <Nav />\r\n          <Switch>\r\n              <Route path=\"/about\">\r\n                  <About />\r\n              </Route>\r\n              <Route path=\"/todo\">\r\n                  <Todo />\r\n              </Route>\r\n              <Route path=\"/contact\">\r\n                  <Contact />\r\n              </Route>\r\n          </Switch>\r\n      </Router>\r\n\r\n      <Form addTask={addTask} />\r\n      <div className=\"filters btn-group stack-exception\">\r\n        {filterList}  \r\n      </div>\r\n      <h2 id=\"list-heading\">{headingText}</h2>\r\n      <ul\r\n        role=\"list\"\r\n        className=\"todo-list stack-large stack-exception\"\r\n        aria-labelledby=\"list-heading\"\r\n      >\r\n        {taskList}\r\n      </ul>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default App;","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\Contact.js",[],"C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\About.js",["42","43"],"import React, {useState, useEffect} from 'react';\r\n\r\nfunction About(props) {\r\n    return (\r\n        <div>\r\n            <h1>About</h1>\r\n            <div>The following application is a task management system that was designed using React.</div>\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default About;","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\Form.js",[],"C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\FilterButton.js",[],"C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\Nav.js",["44"],"import React, { useState } from \"react\";\r\nimport {\r\n    Link\r\n  } from \"react-router-dom\";\r\n\r\n\r\nfunction Nav(props) {\r\n    return (\r\n        \r\n            <div className={\"nav-list\"}>\r\n                <div className={\"list-item\"}>\r\n                    <Link to=\"/about\" activeClassName=\"underline text-white\">\r\n                        <span className={'text-xl text-white font-bold cursor-pointer'}>About</span>\r\n                    </Link>\r\n                </div>\r\n                <div className={\"list-item\"}>\r\n                    <Link to=\"/todos\" activeClassName=\"underline text-white\">\r\n                        <span className={'text-xl text-white font-bold cursor-pointer'}>Todos</span>\r\n                    </Link>\r\n                </div>\r\n                <div className={\"list-item\"}>\r\n                    <Link to=\"/contact\" activeClassName=\"underline text-white\">\r\n                        <span className={'text-xl text-white font-bold cursor-pointer'}>Contact</span>\r\n                    </Link>\r\n                </div>\r\n            </div>\r\n        \r\n    );\r\n}\r\n\r\n\r\nexport default Nav;\r\n","C:\\Users\\scott\\Documents\\VSC-projects\\react\\Project-3\\src\\components\\Todo.js",[],{"ruleId":"45","replacedBy":"46"},{"ruleId":"47","replacedBy":"48"},{"ruleId":"49","severity":1,"message":"50","line":11,"column":3,"nodeType":"51","messageId":"52","endLine":11,"endColumn":7},{"ruleId":"53","severity":1,"message":"54","line":112,"column":7,"nodeType":"55","endLine":116,"endColumn":8},{"ruleId":"49","severity":1,"message":"56","line":1,"column":16,"nodeType":"51","messageId":"52","endLine":1,"endColumn":24},{"ruleId":"49","severity":1,"message":"57","line":1,"column":26,"nodeType":"51","messageId":"52","endLine":1,"endColumn":35},{"ruleId":"49","severity":1,"message":"56","line":1,"column":17,"nodeType":"51","messageId":"52","endLine":1,"endColumn":25},"no-native-reassign",["58"],"no-negated-in-lhs",["59"],"no-unused-vars","'Link' is defined but never used.","Identifier","unusedVar","jsx-a11y/no-redundant-roles","The element ul has an implicit role of list. Defining this explicitly is redundant and should be avoided.","JSXOpeningElement","'useState' is defined but never used.","'useEffect' is defined but never used.","no-global-assign","no-unsafe-negation"]